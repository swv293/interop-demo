{
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "Pipeline KPIs",
      "queryLines": [
        "SELECT * FROM serverless_stable_swv01_catalog.dashboard.v_pipeline_kpis"
      ]
    },
    {
      "name": "ds_doc_types",
      "displayName": "Document Types",
      "queryLines": [
        "SELECT document_type, COUNT(*) AS cnt FROM serverless_stable_swv01_catalog.raw.clinical_document GROUP BY document_type ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_channels",
      "displayName": "Intake Channels",
      "queryLines": [
        "SELECT source_channel, COUNT(*) AS cnt FROM serverless_stable_swv01_catalog.raw.clinical_document GROUP BY source_channel ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_auth_status",
      "displayName": "Auth Status",
      "queryLines": [
        "SELECT status, COUNT(*) AS cnt, ROUND(COUNT(*)*100.0/SUM(COUNT(*)) OVER(),1) AS pct FROM serverless_stable_swv01_catalog.raw.authorization GROUP BY status ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_dq",
      "displayName": "DQ Metrics",
      "queryLines": [
        "SELECT * FROM serverless_stable_swv01_catalog.dashboard.v_dq_metrics"
      ]
    },
    {
      "name": "ds_risk_tiers",
      "displayName": "Risk Tiers",
      "queryLines": [
        "SELECT doc_risk_tier, COUNT(*) AS cnt FROM serverless_stable_swv01_catalog.dashboard.v_doc_match_status GROUP BY doc_risk_tier ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_dq_thresholds",
      "displayName": "DQ Thresholds",
      "queryLines": [
        "SELECT 'Pct Unreadable' AS check_name, ROUND(100.0*SUM(CASE WHEN unreadable_flag THEN 1 ELSE 0 END)/COUNT(*),2) AS value, '< 15%' AS threshold, CASE WHEN 100.0*SUM(CASE WHEN unreadable_flag THEN 1 ELSE 0 END)/COUNT(*) < 15 THEN 'PASS' ELSE 'FAIL' END AS status FROM serverless_stable_swv01_catalog.curated.clinical_doc_parsed UNION ALL SELECT 'Pct Missing DOB', ROUND(100.0*SUM(CASE WHEN extracted_dob IS NULL THEN 1 ELSE 0 END)/COUNT(*),2), '< 20%', CASE WHEN 100.0*SUM(CASE WHEN extracted_dob IS NULL THEN 1 ELSE 0 END)/COUNT(*) < 20 THEN 'PASS' ELSE 'FAIL' END FROM serverless_stable_swv01_catalog.curated.clinical_doc_parsed WHERE unreadable_flag=false UNION ALL SELECT 'Pct Missing SSN4', ROUND(100.0*SUM(CASE WHEN extracted_ssn4 IS NULL OR extracted_ssn4='' THEN 1 ELSE 0 END)/COUNT(*),2), '< 25%', CASE WHEN 100.0*SUM(CASE WHEN extracted_ssn4 IS NULL OR extracted_ssn4='' THEN 1 ELSE 0 END)/COUNT(*) < 25 THEN 'PASS' ELSE 'FAIL' END FROM serverless_stable_swv01_catalog.curated.clinical_doc_parsed WHERE unreadable_flag=false UNION ALL SELECT 'Avg Parse Confidence', ROUND(AVG(parse_confidence),3), '> 0.7', CASE WHEN AVG(parse_confidence) > 0.7 THEN 'PASS' ELSE 'FAIL' END FROM serverless_stable_swv01_catalog.curated.clinical_doc_parsed WHERE unreadable_flag=false"
      ]
    },
    {
      "name": "ds_match_summary",
      "displayName": "Match Summary",
      "queryLines": [
        "SELECT * FROM serverless_stable_swv01_catalog.dashboard.v_match_summary"
      ]
    },
    {
      "name": "ds_score_dist",
      "displayName": "Score Distribution",
      "queryLines": [
        "SELECT * FROM serverless_stable_swv01_catalog.dashboard.v_score_distribution ORDER BY weight_bucket"
      ]
    },
    {
      "name": "ds_auth_match",
      "displayName": "Auth Match Summary",
      "queryLines": [
        "SELECT * FROM serverless_stable_swv01_catalog.dashboard.v_auth_match_summary"
      ]
    },
    {
      "name": "ds_fs_params",
      "displayName": "F-S Parameters",
      "queryLines": [
        "SELECT field_name, m_probability, u_probability, ROUND(agreement_weight,2) AS agreement_weight, ROUND(disagreement_weight,2) AS disagreement_weight, field_weight_multiplier FROM serverless_stable_swv01_catalog.analytics.fellegi_sunter_parameters ORDER BY agreement_weight DESC"
      ]
    }
  ],
